#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

if [[ -f "$ROOT/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/.env"
  set +a
fi

VENV="$ROOT/.venv"
if [[ ! -x "$VENV/bin/python" ]]; then
  echo "Creating .venv..."
  python3.11 -m venv "$VENV" 2>/dev/null || python3 -m venv "$VENV"
fi

"$VENV/bin/pip" install -q prompt_toolkit python-dotenv 2>/dev/null || true

exec "$VENV/bin/python" "$ROOT/paleo_chat.py"
